APP_NAME=Distributed Spot Controller Main Web Server
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:////absolute/path/to/backend/data/server.db
PUBLIC_BASE_URL=http://localhost:8000
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123!
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_NAME=dssc_csrf
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TTL_SECONDS=43200
PROTOCOL_VERSION=1
PROTOCOL_MINOR_VERSION=0
SIGNED_DOWNLOAD_TTL_SECONDS=600
COMMAND_ACK_TIMEOUT_SECONDS=5
HEARTBEAT_SWEEP_INTERVAL_SECONDS=10
HEARTBEAT_STALE_AFTER_SECONDS=45
HEARTBEAT_OFFLINE_AFTER_SECONDS=90
EVENT_RETENTION_DAYS=30
INACTIVE_SPOT_RETENTION_DAYS=14
RETENTION_SWEEP_INTERVAL_HOURS=12
ENROLLMENT_CODE_LENGTH=6
ENROLLMENT_TTL_SECONDS=1800
